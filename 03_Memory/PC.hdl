CHIP PC {
    IN in[16], reset, load, inc;
    OUT out[16];
    
    PARTS:
    Inc16(in= feedback, out= outInc);
    Mux16(a= in, b= outInc, sel= inc, out= outMuxInc);
    Mux16(a= outMuxInc, b= in, sel= load, out= outMuxLoad);
    Mux16(a= outMuxLoad, b= false, sel= reset, out= outMuxReset);
    Register(in= outMuxReset, load= true, out=feedback, out= out);
}